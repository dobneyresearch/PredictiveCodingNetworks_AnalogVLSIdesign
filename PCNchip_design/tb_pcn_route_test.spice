+ m0_ipred_0 m0_ipred_1 m0_ipred_2 m0_ipred_3 m0_ipred_4 m0_ipred_5 m0_ipred_6 m0_ipred_7 m0_ipred_8 m0_ipred_9 m0_ipred_10 m0_ipred_11 m0_ipred_12 m0_ipred_13 m0_ipred_14 m0_ipred_15
+ m0_ierr_0 m0_ierr_1 m0_ierr_2 m0_ierr_3 m0_ierr_4 m0_ierr_5 m0_ierr_6 m0_ierr_7 m0_ierr_8 m0_ierr_9 m0_ierr_10 m0_ierr_11 m0_ierr_12 m0_ierr_13 m0_ierr_14 m0_ierr_15
+ vss vss vss vss  vss vss vss vss  vss vss vss vss  vss vss vss vss
+ vpi vpi vpi vpi  vpi vpi vpi vpi  vpi vpi vpi vpi  vpi vpi vpi vpi
+ vbias_p  vbias_n  vcm  vdd  vss
+ pcn_module_16x32

* ── layer_link_route_16 ──────────────────────────────────────────────────────
* iout_upper: vss (no upper module; only one-layer routing test)
* sf_out_r:   ascending SF output test nodes
Xlink
+ m0_iout_0 m0_iout_1 m0_iout_2 m0_iout_3 m0_iout_4 m0_iout_5 m0_iout_6 m0_iout_7 m0_iout_8 m0_iout_9 m0_iout_10 m0_iout_11 m0_iout_12 m0_iout_13 m0_iout_14 m0_iout_15
+ sf_out_0 sf_out_1 sf_out_2 sf_out_3 sf_out_4 sf_out_5 sf_out_6 sf_out_7 sf_out_8 sf_out_9 sf_out_10 sf_out_11 sf_out_12 sf_out_13 sf_out_14 sf_out_15
+ m0_ipred_0 m0_ipred_1 m0_ipred_2 m0_ipred_3 m0_ipred_4 m0_ipred_5 m0_ipred_6 m0_ipred_7 m0_ipred_8 m0_ipred_9 m0_ipred_10 m0_ipred_11 m0_ipred_12 m0_ipred_13 m0_ipred_14 m0_ipred_15
+ vss vss vss vss  vss vss vss vss  vss vss vss vss  vss vss vss vss
+ m0_ierr_0 m0_ierr_1 m0_ierr_2 m0_ierr_3 m0_ierr_4 m0_ierr_5 m0_ierr_6 m0_ierr_7 m0_ierr_8 m0_ierr_9 m0_ierr_10 m0_ierr_11 m0_ierr_12 m0_ierr_13 m0_ierr_14 m0_ierr_15
+ we_route
+ vcm_route  nvcm_upper  ncm_iout  vbias_n  vdd  vss
+ layer_link_route_16

* ── Nodesets ────────────────────────────────────────────────────────────────
* iout balanced OP: ~0.47V (PMOS mirror fix §70; current_sub XMPS1 loads below Vcm)
* PMOS SF output: iout_balance + |Vgs_P| ≈ 0.47 + 0.67 = 1.14V (§71)
.nodeset V(m0_iout_0)=0.47  V(m0_iout_1)=0.47
.nodeset V(nvcm_upper)=1.14
.nodeset V(sf_out_0)=1.14

.control
  set filetype = ascii

  echo ""
  echo "======================================================="
  echo " PCN 16x32 routing test — 400ns tran"
  echo "======================================================="

  tran 0.5n 400n uic

  * T1: pre-pulse state at t=45ns (vw_route[0][0]=0.75V pre-set; before first WE_route)
  echo ""
  echo " T1 — pre-pulse (t=45ns, vw_route[0][0]=0.75V pre-set):"
  meas tran T1_iout0   FIND V(m0_iout_0)            AT=45n
  meas tran T1_iout1   FIND V(m0_iout_1)            AT=45n
  meas tran T1_sf0     FIND V(sf_out_0)             AT=45n
  meas tran T1_ierr0   FIND V(m0_ierr_0)            AT=45n
  meas tran T1_ipred0  FIND V(m0_ipred_0)           AT=45n
  meas tran T1_vw00    FIND V(xlink.vw_route_0_0)   AT=45n

  echo "   V(m0_iout_0)            = " $&T1_iout0   " V  (active row; ~1.03V expected)"
  echo "   V(m0_iout_1)            = " $&T1_iout1   " V  (balanced row; ~1.03V)"
  echo "   V(sf_out_0)             = " $&T1_sf0     " V  (PMOS SF output; expect ~1.14V)"
  echo "   V(m0_ierr_0)            = " $&T1_ierr0   " V  (error flag; expect HIGH=1.8V: over-prediction)"
  echo "   V(m0_ipred_0)           = " $&T1_ipred0  " V  (prediction; LOW: XMPRED_r sinking)"
  echo "   V(xlink.vw_route_0_0)   = " $&T1_vw00    " V  (routing weight; expect ~0.75V pre-set)"

  * T3: Hebbian write pulses — first pulse at t=50ns; expect LTD (weight decreases)
  echo ""
  echo " T3 — Hebbian LTD write (WE_route pulses at t=50,100,150... ns):"
  meas tran T3_we_mid    FIND V(we_route)            AT=52n
  meas tran T3_ierr_mid  FIND V(m0_ierr_0)           AT=52n
  meas tran T3_vw_p1     FIND V(xlink.vw_route_0_0)  AT=70n
  meas tran T3_vw_p2     FIND V(xlink.vw_route_0_0)  AT=120n
  meas tran T3_vw_p3     FIND V(xlink.vw_route_0_0)  AT=170n

  echo "   V(we_route)    t=52ns   = " $&T3_we_mid    " V  (expect 1.8V during pulse)"
  echo "   V(m0_ierr_0)   t=52ns   = " $&T3_ierr_mid  " V  (expect HIGH=1.8V: enables Hebbian write)"
  echo "   Vw_route[0][0] after p1 (t=70ns)  = " $&T3_vw_p1  " V  (expect < 0.75V: LTD)"
  echo "   Vw_route[0][0] after p2 (t=120ns) = " $&T3_vw_p2  " V"
  echo "   Vw_route[0][0] after p3 (t=170ns) = " $&T3_vw_p3  " V"

  if T3_vw_p1 < T1_vw00
    echo "   PASS: routing weight DECREASED after pulse 1 (LTD confirmed — correct adaptive response)"
  else
    echo "   NOTE: routing weight did not decrease — check ierr_dig level and Hebbian write path"
  end

  * T2: trained state at t=380ns (after 7 LTD pulses from vw_route[0][0]=0.75V)
  echo ""
  echo " T2 — trained state (t=380ns, 7 LTD write pulses applied):"
  meas tran T2_iout0   FIND V(m0_iout_0)            AT=380n
  meas tran T2_sf0     FIND V(sf_out_0)             AT=380n
  meas tran T2_ierr0   FIND V(m0_ierr_0)            AT=380n
  meas tran T2_ipred0  FIND V(m0_ipred_0)           AT=380n
  meas tran T2_vw00    FIND V(xlink.vw_route_0_0)   AT=380n

  echo "   V(m0_iout_0)            = " $&T2_iout0   " V"
  echo "   V(sf_out_0)             = " $&T2_sf0     " V"
  echo "   V(m0_ierr_0)            = " $&T2_ierr0   " V  (should approach LOW as weight corrects over-prediction)"
  echo "   V(m0_ipred_0)           = " $&T2_ipred0  " V  (prediction sinking reduces as weight drops)"
  echo "   V(xlink.vw_route_0_0)   = " $&T2_vw00    " V  (expect < 0.75V after LTD accumulation)"

  echo ""
  echo " Weight trajectory (LTD from 0.75V):"
  echo "   0.75V → p1: " $&T3_vw_p1 " V → p2: " $&T3_vw_p2 " V → p3: " $&T3_vw_p3 " V → t=380ns: " $&T2_vw00 " V"

  wrdata output/t1_t2_t3_route.csv V(xlink.vw_route_0_0) V(m0_ierr_0) V(m0_iout_0) V(m0_iout_1) V(sf_out_0) V(m0_ipred_0) V(we_route)
  echo ""
  echo " Saved: output/t1_t2_t3_route.csv"
.endc

.end
