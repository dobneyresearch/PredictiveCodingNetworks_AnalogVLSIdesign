.nodeset V(xmod3.xarray.iwrite_15_0)=0.9  V(xmod3.xarray.iwrite_15_1)=0.9  V(xmod3.xarray.iwrite_15_2)=0.9  V(xmod3.xarray.iwrite_15_3)=0.9  V(xmod3.xarray.iwrite_15_4)=0.9  V(xmod3.xarray.iwrite_15_5)=0.9  V(xmod3.xarray.iwrite_15_6)=0.9  V(xmod3.xarray.iwrite_15_7)=0.9  V(xmod3.xarray.iwrite_15_8)=0.9  V(xmod3.xarray.iwrite_15_9)=0.9  V(xmod3.xarray.iwrite_15_10)=0.9  V(xmod3.xarray.iwrite_15_11)=0.9  V(xmod3.xarray.iwrite_15_12)=0.9  V(xmod3.xarray.iwrite_15_13)=0.9  V(xmod3.xarray.iwrite_15_14)=0.9  V(xmod3.xarray.iwrite_15_15)=0.9

* =============================================================================
.control

  set filetype = ascii

  * ──────────────────────────────────────────────────────────────────────────
  * T1: Operating point — all inputs at Vcm, all WE=0
  * ──────────────────────────────────────────────────────────────────────────
  echo ""
  echo "======================================================"
  echo " T1: 4-layer operating point"
  echo "======================================================"

  op

  * Bias rails
  echo "  --- Bias rails ---"
  echo "  V(vbias_n)       = " $&V(vbias_n)       "  (target: 0.760)"
  echo "  V(vcm)           = " $&V(vcm)           "  (target: 0.900)"
  echo "  V(vpi)           = " $&V(vpi)           "  (target: 0.650)"
  echo "  V(ncm_iout)      = " $&V(ncm_iout)      "  (balanced iout OP stiff; target 0.468)"
  echo "  V(vcm_upper_01)  = " $&V(vcm_upper_01) "  (PMOS SF ref out; target ≈1.14)"
  echo "  V(vcm_upper_12)  = " $&V(vcm_upper_12) "  (PMOS SF ref out; target ≈1.14)"
  echo "  V(vcm_upper_23)  = " $&V(vcm_upper_23) "  (PMOS SF ref out; target ≈1.14)"
  echo ""

  * Ascending signal path (row 0)
  echo "  --- Ascending signal path (row 0) ---"
  echo "  V(m0_iout_0)  = " $&V(m0_iout_0)  "  (mod0 KCL bus; target ≈0.468)"
  echo "  V(m1_inp_0)   = " $&V(m1_inp_0)   "  (PMOS SF out → mod1 col; target ≈1.14)"
  echo "  V(m1_iout_0)  = " $&V(m1_iout_0)  "  (mod1 KCL bus; target ≈0.468 after §72 fix)"
  echo "  V(m2_inp_0)   = " $&V(m2_inp_0)   "  (PMOS SF out → mod2 col)"
  echo "  V(m2_iout_0)  = " $&V(m2_iout_0)  "  (mod2 KCL bus)"
  echo "  V(m3_inp_0)   = " $&V(m3_inp_0)   "  (PMOS SF out → mod3 col)"
  echo "  V(m3_iout_0)  = " $&V(m3_iout_0)  "  (mod3 KCL bus, chip top output)"

  * Ascending level shifts (PMOS SF: expect POSITIVE ~+0.65V)
  let shift_01 = V(m1_inp_0) - V(m0_iout_0)
  let shift_12 = V(m2_inp_0) - V(m1_iout_0)
  let shift_23 = V(m3_inp_0) - V(m2_iout_0)
  echo "  Level shift link01 (PMOS SF): " $&shift_01 "V  (expect +0.65V: SF raises)"
  echo "  Level shift link12 (PMOS SF): " $&shift_12 "V"
  echo "  Level shift link23 (PMOS SF): " $&shift_23 "V"
  echo ""

  * Descending prediction path
  echo "  --- Descending prediction path ---"
  echo "  V(m2_pred_0) = " $&V(m2_pred_0)
  echo "  V(m1_pred_0) = " $&V(m1_pred_0)
  echo "  V(m0_pred_0) = " $&V(m0_pred_0)
  echo ""

  * Error flags
  echo "  --- Error flags row 0 (HIGH = fires) ---"
  echo "  ierr_m0_0 = " $&V(ierr_m0_0)
  echo "  ierr_m1_0 = " $&V(ierr_m1_0)
  echo "  ierr_m2_0 = " $&V(ierr_m2_0)
  echo "  ierr_m3_0 = " $&V(ierr_m3_0) "  (i_pred=VSS → always HIGH)"
  echo ""

  * PASS/FAIL: PMOS SF raises voltage (positive shift)
  if shift_01 > 0
    echo "  PASS: link01 shift positive (PMOS SF raises)"
  else
    echo "  WARN: link01 shift non-positive — check PMOS SF"
  end
  if shift_12 > 0
    echo "  PASS: link12 shift positive"
  else
    echo "  WARN: link12 shift non-positive"
  end
  if shift_23 > 0
    echo "  PASS: link23 shift positive"
  else
    echo "  WARN: link23 shift non-positive"
  end

  * Check upper diff pairs receive sufficient input voltage
  if V(m1_inp_0) > 0.6
    echo "  PASS: mod1 inp > 0.6V (PMOS SF spatial fix working)"
  else
    echo "  WARN: mod1 inp too low — spatial pipeline may be dead"
  end

  * §72 fix check: mod1 KCL bus should be balanced (not collapsed)
  if V(m1_iout_0) > 0.3
    echo "  PASS: mod1 iout > 0.3V — diff pair balanced (§72 vcm_iout fix working)"
  else
    echo "  WARN: mod1 iout < 0.3V — vcm_upper mismatch (ref SF gate needs §72 fix)"
  end

  * §72 fix check: vcm_upper should match m1_inp at balance (within 0.1V)
  let vcmu_err = abs(V(vcm_upper_01) - V(m1_inp_0))
  if vcmu_err < 0.1
    echo "  PASS: vcm_upper ≈ m1_inp (§72 reference SF tracking correctly)"
  else
    echo "  WARN: vcm_upper offset " $&vcmu_err "V from m1_inp — check ncm_iout bias"
  end

  if V(ierr_m3_0) > 0.9
    echo "  PASS: mod3 ierr_dig HIGH (top layer fires)"
  else
    echo "  WARN: mod3 ierr_dig LOW"
  end

  write output/t1_4layer_op.raw
  echo "  Saved: output/t1_4layer_op.raw"

  * ──────────────────────────────────────────────────────────────────────────
  * T2: DC sweep — raw_inp_0 ±50mV, signal gain through 4 layers
  * ──────────────────────────────────────────────────────────────────────────
  echo ""
  echo "======================================================"
  echo " T2: DC sweep — ascending signal gain"
  echo "======================================================"

  dc Vinp0 0.85 0.95 0.005

  meas dc Vm0iout0_lo  FIND V(m0_iout_0)  WHEN V(raw_inp_0)=0.86 CROSS=1
  meas dc Vm0iout0_hi  FIND V(m0_iout_0)  WHEN V(raw_inp_0)=0.94 CROSS=1
  meas dc Vm1inp0_lo  FIND V(m1_inp_0)  WHEN V(raw_inp_0)=0.86 CROSS=1
  meas dc Vm1inp0_hi  FIND V(m1_inp_0)  WHEN V(raw_inp_0)=0.94 CROSS=1
  meas dc Vm1iout0_lo  FIND V(m1_iout_0)  WHEN V(raw_inp_0)=0.86 CROSS=1
  meas dc Vm1iout0_hi  FIND V(m1_iout_0)  WHEN V(raw_inp_0)=0.94 CROSS=1
  meas dc Vm2inp0_lo  FIND V(m2_inp_0)  WHEN V(raw_inp_0)=0.86 CROSS=1
  meas dc Vm2inp0_hi  FIND V(m2_inp_0)  WHEN V(raw_inp_0)=0.94 CROSS=1
  meas dc Vm2iout0_lo  FIND V(m2_iout_0)  WHEN V(raw_inp_0)=0.86 CROSS=1
  meas dc Vm2iout0_hi  FIND V(m2_iout_0)  WHEN V(raw_inp_0)=0.94 CROSS=1
  meas dc Vm3inp0_lo  FIND V(m3_inp_0)  WHEN V(raw_inp_0)=0.86 CROSS=1
  meas dc Vm3inp0_hi  FIND V(m3_inp_0)  WHEN V(raw_inp_0)=0.94 CROSS=1
  meas dc Vm3iout0_lo  FIND V(m3_iout_0)  WHEN V(raw_inp_0)=0.86 CROSS=1
  meas dc Vm3iout0_hi  FIND V(m3_iout_0)  WHEN V(raw_inp_0)=0.94 CROSS=1

  let dV_m0iout0 = Vm0iout0_hi - Vm0iout0_lo
  echo "  V(m0_iout_0) swing over 80mV: " $&dV_m0iout0 " V"
  let dV_m1inp0 = Vm1inp0_hi - Vm1inp0_lo
  echo "  V(m1_inp_0) swing over 80mV: " $&dV_m1inp0 " V"
  let dV_m1iout0 = Vm1iout0_hi - Vm1iout0_lo
  echo "  V(m1_iout_0) swing over 80mV: " $&dV_m1iout0 " V"
  let dV_m2inp0 = Vm2inp0_hi - Vm2inp0_lo
  echo "  V(m2_inp_0) swing over 80mV: " $&dV_m2inp0 " V"
  let dV_m2iout0 = Vm2iout0_hi - Vm2iout0_lo
  echo "  V(m2_iout_0) swing over 80mV: " $&dV_m2iout0 " V"
  let dV_m3inp0 = Vm3inp0_hi - Vm3inp0_lo
  echo "  V(m3_inp_0) swing over 80mV: " $&dV_m3inp0 " V"
  let dV_m3iout0 = Vm3iout0_hi - Vm3iout0_lo
  echo "  V(m3_iout_0) swing over 80mV: " $&dV_m3iout0 " V"

  echo ""
  let gain_m0iout0 = dV_m0iout0 / 0.08
  echo "  mod0 gain (raw→iout): " $&gain_m0iout0
  let gain_m1inp0 = dV_m1inp0 / dV_m0iout0
  echo "  link01 SF gain: " $&gain_m1inp0
  let gain_m1iout0 = dV_m1iout0 / dV_m1inp0
  echo "  mod1 gain (inp→iout): " $&gain_m1iout0
  let gain_m2inp0 = dV_m2inp0 / dV_m1iout0
  echo "  link12 SF gain: " $&gain_m2inp0
  let gain_m2iout0 = dV_m2iout0 / dV_m2inp0
  echo "  mod2 gain (inp→iout): " $&gain_m2iout0
  let gain_m3inp0 = dV_m3inp0 / dV_m2iout0
  echo "  link23 SF gain: " $&gain_m3inp0
  let gain_m3iout0 = dV_m3iout0 / dV_m3inp0
  echo "  mod3 gain (inp→iout): " $&gain_m3iout0

  let abs_swing_m3 = abs(dV_m3iout0)
  if abs_swing_m3 > 0.001
    echo "  PASS: signal propagates through all 4 layers"
  else
    echo "  FAIL: no signal at mod3 — check PMOS SF ascending path"
  end

  wrdata output/t2_4layer_sweep.csv V(raw_inp_0) V(m0_iout_0) V(m1_inp_0) V(m1_iout_0) V(m2_inp_0) V(m2_iout_0) V(m3_inp_0) V(m3_iout_0)
  write  output/t2_4layer_sweep.raw
  echo "  Saved: output/t2_4layer_sweep.csv  output/t2_4layer_sweep.raw"

  * ──────────────────────────────────────────────────────────────────────────
  * T3: Transient — Hebbian write on mod0 row 0
  * ──────────────────────────────────────────────────────────────────────────
  echo ""
  echo "======================================================"
  echo " T3: Transient — Hebbian write mod0 row0"
  echo "======================================================"

  alter @vinp0[dc] = 1.1

  tran 0.5n 120n uic

  meas tran Vw_t110    FIND V(xmod0.xarray.vw_0_0)  AT=110n
  meas tran Vw_t0      FIND V(xmod0.xarray.vw_0_0)  AT=1n
  meas tran Verr_t60   FIND V(ierr_m0_0)              AT=60n
  meas tran Vwe_t60    FIND V(we_m0_0)                AT=60n

  echo "  V(we_m0_0) at t=60ns:   " $&Vwe_t60  "  (expect 1.8V)"
  echo "  V(ierr_m0_0) at t=60ns: " $&Verr_t60
  echo "  V(vw_0_0) t=1n:   " $&Vw_t0
  echo "  V(vw_0_0) t=110n: " $&Vw_t110

  let dVw = Vw_t110 - Vw_t0
  echo "  Delta Vw = " $&dVw " V"

  let dVw_abs = abs(dVw)
  if dVw_abs > 1e-3
    echo "  PASS: weight changed — Hebbian write functional"
  else
    echo "  NOTE: weight unchanged — ierr_dig or WE path may be blocked"
  end

  wrdata output/t3_4layer_hebb.csv V(xmod0.xarray.vw_0_0) V(ierr_m0_0) V(we_m0_0) V(m0_iout_0)
  write  output/t3_4layer_hebb.raw
  echo "  Saved: output/t3_4layer_hebb.csv"

  echo ""
  echo "======================================================"
  echo " All 4-layer tests complete."
  echo "======================================================"

  quit

.endc

.end
